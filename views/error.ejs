<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: title, page: 'error' }) %>
<style>
    body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        background-color: #0b1016; /* Hardcoded fallback */
        background-color: var(--dark-bg);
        text-align: center;
        color: white;
    }
    .error-card {
        background: rgba(21, 30, 41, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 40px;
        border-radius: 20px;
        max-width: 500px;
        width: 90%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        backdrop-filter: blur(10px);
    }
    .error-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        display: block;
    }
    h1 {
        margin-bottom: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    p {
        color: #aaa;
        line-height: 1.6;
        margin-bottom: 30px;
    }
    .btn-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
</style>
<body>
    <div class="error-card">
        <span class="error-icon"><%= locals.icon || '⚠️' %></span>
        <h1><%= title %></h1>
        <p><%= message %></p>
        
        <div class="btn-container">
            <% if (locals.buttons && buttons.length > 0) { %>
                <% buttons.forEach(btn => { %>
                    <a href="<%= btn.link %>" class="btn-cc <%= btn.class || 'btn-primary' %>"><%= btn.label %></a>
                <% }) %>
            <% } else { %>
                <a href="/" class="btn-cc btn-primary">Back to Home</a>
            <% } %>
        </div>
    </div>
</body>
</html>
