<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Photo Gallery', page: 'gallery', description: 'Relive the best moments of Club FuRN! Browse our community-synced photo gallery.' }) %>
<style>
    body {
        background: radial-gradient(circle at top, rgba(179, 106, 244, 0.05), transparent 50%), var(--dark-bg);
    }

    .gallery-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    /* MASONRY LAYOUT */
    .masonry-grid {
        column-count: 4;
        column-gap: 20px;
        width: 100%;
    }

    @media (max-width: 1200px) { .masonry-grid { column-count: 3; } }
    @media (max-width: 800px) { .masonry-grid { column-count: 2; } }
    @media (max-width: 500px) { .masonry-grid { column-count: 1; } }

    .gallery-item {
        break-inside: avoid;
        margin-bottom: 20px;
        background: var(--card-bg);
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.05);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        cursor: pointer;
        opacity: 0;
        transform: translateY(20px);
    }
    .gallery-item.revealed {
        opacity: 1;
        transform: translateY(0);
    }
    .gallery-item:hover {
        transform: scale(1.02);
        border-color: var(--primary-blue);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        z-index: 10;
    }

    .gallery-img {
        width: 100%;
        display: block;
        object-fit: cover;
    }

    .gallery-overlay {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        padding: 20px;
        background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .gallery-item:hover .gallery-overlay {
        opacity: 1;
    }

    .uploader-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .uploader-avatar {
        width: 30px; height: 30px;
        border-radius: 50%;
        border: 2px solid var(--primary-blue);
    }
    .uploader-name {
        font-size: 0.85rem;
        font-weight: bold;
        color: #fff;
    }
    .photo-caption {
        font-size: 0.8rem;
        color: #ccc;
        margin-top: 5px;
        line-height: 1.4;
    }

    #main-title {
        font-size: 4rem;
        text-align: center;
        margin-bottom: 10px;
        font-weight: 900;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    #sub-title {
        text-align: center;
        color: #888;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 50px;
    }

    /* LIGHTBOX */
    #lightbox {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.95);
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
    }
    #lightbox img {
        max-width: 90%;
        max-height: 90%;
        border-radius: 10px;
        box-shadow: 0 0 50px rgba(41, 197, 246, 0.3);
    }
    #lightbox-close {
        position: absolute;
        top: 30px; right: 30px;
        font-size: 2rem;
        color: #fff;
        cursor: pointer;
        opacity: 0.6;
    }
    #lightbox-close:hover { opacity: 1; }
</style>
<body>

    <div class="gallery-container">
        <%- include('partials/nav', { page: 'gallery' }) %>

        <div class="logo-container" style="text-align: center;">
            <img class="logo" src="/cdn/logos/club/Logo.png" alt="Club FuRN Logo"> 
        </div>

        <h1 id="main-title" style="margin-top: 20px;">MOMENTS</h1>
        <p id="sub-title">Club FuRN Photo Gallery</p>

        <div id="loading-gallery" style="text-align: center; margin-top: 100px;">
            <div class="spinner" style="width: 60px; height: 60px;"></div>
            <p style="color:#888; margin-top: 20px;">DEVELOPING PHOTOS...</p>
        </div>

        <div id="gallery-grid" class="masonry-grid">
            <!-- Dynamic Photos Here -->
        </div>

        <p id="empty-msg" class="hidden" style="text-align: center; margin-top: 100px; color: #666;">The gallery is currently empty. Staff can sync photos from Discord!</p>
    </div>

    <div id="lightbox" onclick="this.style.display='none'">
        <span id="lightbox-close">&times;</span>
        <img id="lightbox-img" src="">
    </div>

    <script src="/cdn/js/theme-engine.js"></script>
    <script>
        async function initGallery() {
            // Track View
            fetch("/api/stats/track", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type: 'page_view', targetId: 'gallery', metadata: { page: 'gallery' } })
            }).catch(() => {});

            try {
                const res = await fetch('/api/public/gallery');
                const photos = await res.json();

                const grid = document.getElementById('gallery-grid');
                const loading = document.getElementById('loading-gallery');
                const empty = document.getElementById('empty-msg');

                loading.style.display = 'none';

                if (photos.length === 0) {
                    empty.classList.remove('hidden');
                    return;
                }

                grid.innerHTML = photos.map((p, index) => `
                    <div class="gallery-item" style="transition-delay: ${index * 50}ms">
                        <img src="${p.thumbnailUrl || p.imageUrl}" class="gallery-img" loading="lazy" onclick="openLightbox('${p.imageUrl}')">
                        <div class="gallery-overlay">
                            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                                <div class="uploader-info" onclick="openLightbox('${p.imageUrl}')">
                                    <img src="${p.uploaderAvatar}" class="uploader-avatar">
                                    <span class="uploader-name">${p.uploaderName}</span>
                                </div>
                                <% if (user && (user.type.toLowerCase().includes('host') || user.type.toLowerCase().includes('owner'))) { %>
                                    <button onclick="deletePhoto('${p.id}')" class="btn-cc btn-small btn-danger" style="padding: 5px 10px; font-size: 0.7rem;">Delete</button>
                                <% } %>
                            </div>
                            ${p.caption ? `<p class="photo-caption" onclick="openLightbox('${p.imageUrl}')">${p.caption}</p>` : ''}
                        </div>
                    </div>
                `).join('');

                // Staggered Reveal
                setTimeout(() => {
                    document.querySelectorAll('.gallery-item').forEach(item => item.classList.add('revealed'));
                }, 100);

            } catch (e) {
                console.error(e);
                document.getElementById('loading-gallery').innerHTML = '<p style="color:#ff4444;">Failed to load gallery.</p>';
            }
        }

        async function deletePhoto(id) {
            if (!confirm('Are you sure you want to delete this photo?')) return;
            try {
                const res = await fetch(`/api/gallery/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    initGallery(); // Reload
                } else {
                    alert('Failed to delete photo.');
                }
            } catch (e) {
                console.error(e);
                alert('Network error.');
            }
        }

        function openLightbox(url) {
            const lb = document.getElementById('lightbox');
            const img = document.getElementById('lightbox-img');
            img.src = url;
            lb.style.display = 'flex';
        }

        initGallery();

        async function initGlobal() {
            try {
                const res = await fetch('/api/public/settings');
                const settings = await res.json();
                window.applyGlobalSettings(settings);
            } catch (e) {}
        }

        initGlobal();
    </script>
</body>
</html>
