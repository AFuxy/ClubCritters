<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Community Hub', page: 'index' }) %>
<body class="body-centered">

    <div class="container">
        <%- include('partials/nav', { page: 'index' }) %>

        <div class="logo-container">
            <img class="logo" src="/cdn/logos/club/HeadOnly.png" alt="Club FuRN Logo"> 
        </div>

        <h1 id="main-title">Furry Rave Night</h1>
        <p id="status-subtext">Community Hub</p>
        
        <div id="status-badge-container"></div>

        <div id="loading-view" class="hidden">
            <div class="spinner"></div>
            <p>Loading Schedule...</p>
        </div>

        <div id="offline-view">
            <div id="featured-container"></div>

            <div class="btn-group">
                <a href="https://discord.gg/zcm4feMZmn" class="btn-cc btn-primary">Join our Discord</a>
                <div class="grid-buttons">
                    <a href="https://vrc.group/FURN.9601" class="btn-cc btn-secondary btn-small">VRChat Group</a>
                    <a href="https://vrc.tl/furry-rave-night" class="btn-cc btn-secondary btn-small">VRC.TL Page</a>
                </div>
            </div>
        </div>

        <div id="event-view" class="hidden">
            <div class="event-links-box">
                <p>Event Links</p>
                <a href="https://discord.gg/zcm4feMZmn" class="btn-cc btn-primary btn-small" style="margin-bottom:10px;">Join our Discord</a>
                <div class="grid-buttons">
                    <a href="https://vrc.group/FURN.9601" class="btn-cc btn-secondary btn-small">VRC Group</a>
                    <a href="https://vrc.tl/furry-rave-night" class="btn-cc btn-secondary btn-small">VRC.TL Calendar</a>
                </div>
            </div>

            <div id="dj-container" class="dj-list">
                </div>
        </div>

        </div>

    <script src="/cdn/js/theme-engine.js"></script>
    <script src="/cdn/js/main.js"></script>

    <!-- SLEEK MOTION TOGGLE -->
    <button id="motion-toggle-btn" 
            onclick="window.toggleMotion()"
            style="position: fixed; bottom: 20px; right: 20px; z-index: 1000; 
                   display: none;
                   background: rgba(0,0,0,0.5); backdrop-filter: blur(10px); 
                   border: 1px solid rgba(255,255,255,0.1); color: #888; 
                   padding: 8px 15px; border-radius: 30px; font-size: 0.7rem; 
                   font-weight: 900; letter-spacing: 1px; text-transform: uppercase;
                   cursor: pointer; transition: all 0.3s ease; opacity: 0.6;"
            onmouseover="this.style.opacity='1'; this.style.borderColor='var(--primary-blue)'; this.style.color='#fff';"
            onmouseout="this.style.opacity='0.6'; this.style.borderColor='rgba(255,255,255,0.1)'; this.style.color='#888';">
        🌑 Disable Effects
    </button>
</body>
</html>
