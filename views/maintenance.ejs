<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Resting our Paws', page: 'maintenance' }) %>
<style>
    body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        background-color: #0b1016;
        background-color: var(--dark-bg);
        text-align: center;
        color: white;
        overflow: hidden;
    }
    .maintenance-card {
        background: rgba(21, 30, 41, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 50px 40px;
        border-radius: 24px;
        max-width: 550px;
        width: 90%;
        box-shadow: 0 25px 60px rgba(0,0,0,0.6);
        backdrop-filter: blur(12px);
        position: relative;
        z-index: 2;
    }
    .maintenance-icon {
        font-size: 5rem;
        margin-bottom: 25px;
        display: block;
        filter: drop-shadow(0 0 15px rgba(41, 197, 246, 0.3));
    }
    h1 {
        margin-bottom: 15px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 3px;
        font-size: 2.2rem;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    p {
        color: #b0b8c1;
        line-height: 1.8;
        margin-bottom: 35px;
        font-size: 1.1rem;
    }
    .badge-maintenance {
        display: inline-block;
        padding: 6px 16px;
        background: rgba(41, 197, 246, 0.1);
        border: 1px solid rgba(41, 197, 246, 0.3);
        color: #29C5F6;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
    }
    .loader-dots {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-bottom: 20px;
    }
    .dot {
        width: 8px;
        height: 8px;
        background: #29C5F6;
        border-radius: 50%;
        animation: pulse 1.5s infinite ease-in-out;
    }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }

    @keyframes pulse {
        0%, 100% { opacity: 0.3; transform: scale(0.8); }
        50% { opacity: 1; transform: scale(1.2); }
    }

    /* Ambient background paws */
    .ambient-paws {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
        opacity: 0.03;
    }
</style>
<body>
    <div class="ambient-paws">
        <!-- You could add SVG paws here if needed, but keeping it light for now -->
    </div>

    <div class="maintenance-card">
        <div class="badge-maintenance">System Maintenance</div>
        <span class="maintenance-icon">🐾🚧</span>
        <h1>Under Maintenance</h1>
        <p>
            The Club Critters Hub is currently undergoing maintenance. 
            We're performing system upgrades and deep-burrow optimizations to ensure everything is extra cozy. 
            We'll be back online once the work is complete—thanks for your patience!
        </p>
        
        <div style="margin-bottom: 25px; font-size: 0.9rem; color: #29C5F6; font-weight: 700; letter-spacing: 2px; min-height: 1.2rem; text-transform: uppercase;">
            <span id="typing-status" style="opacity: 0.9;"></span><span class="cursor">|</span>
        </div>

        <div class="loader-dots">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>

        <div class="btn-container" style="margin-top: 30px; display: flex; justify-content: center;">
            <a href="https://discord.gg/zcm4feMZmn" class="btn-cc btn-primary" style="padding: 12px 30px; font-size: 1rem;">Join our Discord</a>
        </div>
    </div>

    <script>
        const statusElement = document.getElementById('typing-status');
        const messages = [
            "ADDING NEW TRICKS",
            "FLUFFING THE PILLOWS",
            "SWEEPING THE BURROW",
            "TIDYING THE NEST",
            "POLISHING THE PAWS",
            "ORGANIZING THE ACORNS"
        ];
        
        let messageIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        let typeSpeed = 100;

        function type() {
            const currentMessage = messages[messageIndex];
            
            if (isDeleting) {
                statusElement.textContent = currentMessage.substring(0, charIndex - 1);
                charIndex--;
                typeSpeed = 50;
            } else {
                statusElement.textContent = currentMessage.substring(0, charIndex + 1);
                charIndex++;
                typeSpeed = 150;
            }

            if (!isDeleting && charIndex === currentMessage.length) {
                isDeleting = true;
                typeSpeed = 2000; // Pause at the end
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                messageIndex = (messageIndex + 1) % messages.length;
                typeSpeed = 500;
            }

            setTimeout(type, typeSpeed);
        }

        document.addEventListener('DOMContentLoaded', type);
    </script>

    <style>
        .cursor {
            display: inline-block;
            width: 2px;
            background-color: #29C5F6;
            margin-left: 2px;
            animation: blink 1s infinite;
            vertical-align: middle;
        }
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
    </style>
</body>
</html>
