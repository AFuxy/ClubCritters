<%- include('header') %>

<style>
    .link-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 15px;
        padding: 20px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 15px;
        text-decoration: none;
        color: white;
        margin-bottom: 15px;
    }
    .link-card:hover {
        background: rgba(41, 197, 246, 0.1);
        border-color: var(--primary-blue);
        transform: translateX(10px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }
    .link-icon {
        width: 40px;
        height: 40px;
        background: var(--primary-gradient);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }
    .link-info h3 {
        margin: 0;
        font-size: 1.1rem;
        color: var(--primary-blue);
    }
    .link-info p {
        margin: 5px 0 0 0;
        font-size: 0.85rem;
        color: #888;
    }
</style>

<div class="staff-hub">
    <div class="staff-section">
        <h2>Staff Quick Links</h2>
        <p style="color: #888; font-size: 0.9rem; margin-bottom: 30px;">Direct access to official Club Critters platforms and community management tools.</p>

        <div class="grid-2">
            <!-- PRIMARY HUB & CHANNELS -->
            <div>
                <h3 style="color: #fff; margin-bottom: 15px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Internal Hubs</h3>
                
                <a href="https://discord.com/channels/1462247751864549386/1462255609423335475" target="_blank" class="link-card">
                    <div class="link-icon">💬</div>
                    <div class="link-info">
                        <h3>Staff Discord Channel</h3>
                        <p>Jump directly to the staff coordination chat.</p>
                    </div>
                </a>

                <a href="https://vrc.group/<%= process.env.VRC_GROUPID || 'CLUBLC.9601' %>" target="_blank" class="link-card">
                    <div class="link-icon">🦊</div>
                    <div class="link-info">
                        <h3>VRChat Group</h3>
                        <p>Manage the official Club Critters group and instances.</p>
                    </div>
                </a>
            </div>

            <!-- PUBLIC SOCIALS -->
            <div>
                <h3 style="color: #fff; margin-bottom: 15px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Public Socials</h3>

                <a href="https://bsky.app/profile/critters.club" target="_blank" class="link-card">
                    <div class="link-icon">🦋</div>
                    <div class="link-info">
                        <h3>Bluesky Profile</h3>
                        <p>Official Club Critters presence on Bluesky.</p>
                    </div>
                </a>

                <a href="https://x.com/Club_Critters" target="_blank" class="link-card">
                    <div class="link-icon">🐦</div>
                    <div class="link-info">
                        <h3>X / Twitter</h3>
                        <p>Official club announcements and community posts.</p>
                    </div>
                </a>
            </div>
        </div>

        <div style="margin-top: 30px; padding: 20px; background: rgba(0,0,0,0.2); border-radius: 10px; border-left: 4px solid var(--primary-purple);">
            <h3 style="margin: 0; color: var(--primary-purple); font-size: 1rem;">Resource Requests:</h3>
            <p style="margin: 10px 0 0 0; color: #aaa; font-size: 0.9rem; line-height: 1.5;">
                If you have suggestions for new links or resources that should be added to this dashboard, please message the **Site Admin** directly on Discord to have them integrated.
            </p>
        </div>
    </div>
</div>

<%- include('footer') %>
