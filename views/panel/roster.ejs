<%- include('header') %>

<div class="staff-hub">
    <div class="staff-section">
        <h2>Roster Manager</h2>
        <p style="font-size: 0.8rem; color: #888; margin-bottom: 20px;">Manage the Club Critters team. Only the Owner can delete users.</p>

        <div id="roster-list" style="display: flex; flex-direction: column; gap: 15px;">
            <!-- Roster items will appear here -->
            <p style="text-align: center; color: #666;">Loading roster...</p>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div id="edit-user-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10000; justify-content:center; align-items:center;">
    <div class="staff-section" style="width: 90%; max-width: 500px; margin-bottom: 0; border: 1px solid var(--primary-blue);">
        <h2 id="edit-modal-title">Edit User</h2>
        
        <div class="form-group">
            <label>Title (e.g. Event Host)</label>
            <input type="text" id="edit-user-title">
        </div>

        <div class="form-group">
            <label>Role Type</label>
            <select id="edit-user-type">
                <option value="Host">Host</option>
                <option value="Staff">Staff</option>
                <option value="Resident">Resident</option>
                <option value="Performer">Performer</option>
            </select>
        </div>

        <div style="display: flex; gap: 10px; margin-top: 20px;">
            <button class="btn-cc btn-primary" style="flex: 1; margin: 0;" onclick="saveUserEdit()">Save Changes</button>
            <button class="btn-cc btn-dark btn-small" style="flex: 0.5; margin: 0;" onclick="closeEditModal()">Cancel</button>
        </div>
    </div>
</div>

<script>
    const rosterList = document.getElementById('roster-list');
    const editModal = document.getElementById('edit-user-modal');
    const editTitleInput = document.getElementById('edit-user-title');
    const editTypeSelect = document.getElementById('edit-user-type');
    
    const isOwner = <%= user.type.toLowerCase().includes('owner') %>;
    const FALLBACK_IMAGE = "/cdn/logos/club/HeadOnly.png";
    let currentEditId = null;

    function parseColor(val) {
        if (!val) return 'var(--primary-blue)';
        if (val.startsWith('[') && val.endsWith(']')) {
            const colors = val.slice(1, -1).split(',').map(c => c.trim());
            return `linear-gradient(135deg, ${colors.join(', ')})`;
        }
        return val;
    }

    async function loadRoster() {
        try {
            const res = await fetch('/api/roster/all');
            const members = await res.json();
            
            rosterList.innerHTML = members.map(m => {
                const accent = parseColor(m.colorStyle);
                const isGradient = accent.includes('gradient');
                const deleteBtn = isOwner && !m.type.toLowerCase().includes('owner') ? 
                    `<button class="btn-cc btn-small btn-danger" onclick="deleteUser('${m.discordId}', '${m.name}')">Delete</button>` : 
                    '';

                return `
                <div class="schedule-item" style="--sidebar-color: ${accent}; background: #151e29; padding: 15px; border-radius: 12px;">
                    <div style="flex: 1; display: flex; align-items: center; gap: 15px; padding-left: 10px;">
                        <img src="${m.imageUrl || FALLBACK_IMAGE}" 
                             onerror="this.src='${FALLBACK_IMAGE}'"
                             style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid; border-color: ${isGradient ? 'var(--primary-blue)' : accent};">
                        <div>
                            <strong style="font-size: 1.15rem; background: ${accent}; -webkit-background-clip: text; -webkit-text-fill-color: ${isGradient ? 'transparent' : 'initial'}; color: ${isGradient ? 'transparent' : accent};">${m.name}</strong>
                            <span style="display: block; font-size: 0.8rem; color: #888; margin-top: 2px;">
                                <span style="color: var(--primary-blue); font-weight: bold;">${m.type}</span> 
                                ${m.title ? '• ' + m.title : ''}
                            </span>
                        </div>
                    </div>
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <button class="btn-cc btn-small btn-dark" onclick="openEditModal('${m.discordId}', '${m.name}', '${m.title || ''}', '${m.type}')">Edit</button>
                        ${deleteBtn}
                    </div>
                </div>
                `;
            }).join('');
        } catch (e) {
            rosterList.innerHTML = '<p style="color: #ff4444; text-align: center;">Error loading roster.</p>';
        }
    }

    function openEditModal(id, name, title, type) {
        currentEditId = id;
        document.getElementById('edit-modal-title').innerText = `Edit ${name}`;
        editTitleInput.value = title;
        if (Array.from(editTypeSelect.options).some(opt => opt.value === type)) {
            editTypeSelect.value = type;
        }
        editModal.style.display = 'flex';
    }

    function closeEditModal() {
        editModal.style.display = 'none';
        currentEditId = null;
    }

    async function saveUserEdit() {
        if (!currentEditId) return;
        try {
            const res = await fetch(`/api/roster/${currentEditId}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title: editTitleInput.value.trim(), type: editTypeSelect.value })
            });
            if (res.ok) {
                showNotify('User updated successfully!');
                closeEditModal();
                loadRoster();
            } else { showNotify('Failed to update user.', 'error'); }
        } catch (e) { showNotify('Network error occurred.', 'error'); }
    }

    async function deleteUser(id, name) {
        if (!confirm(`⚠️ Are you sure you want to permanently delete ${name} from the roster? This cannot be undone.`)) return;
        try {
            const res = await fetch(`/api/roster/${id}`, { method: 'DELETE' });
            if (res.ok) { showNotify(`${name} removed from roster.`); loadRoster(); }
            else { showNotify('Failed to delete user.', 'error'); }
        } catch (e) { showNotify('Error deleting user.', 'error'); }
    }

    loadRoster();
</script>

<%- include('footer') %>
