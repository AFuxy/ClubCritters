<%- include('header') %>

<div class="staff-hub" style="margin-top: 0; grid-column: span 2;">
    
    <!-- API INTEGRATION STATUS -->
    <div class="grid-2" style="margin-bottom: 30px;">
        <!-- VRCHAT API STATUS -->
        <div class="staff-section" style="border-left: 4px solid var(--primary-blue); margin: 0;">
            <h2>VRChat API Integration</h2>
            <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 10px;">
                <div>
                    <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; letter-spacing: 1px;">Current Connection</p>
                    <h3 id="vrc-status-text" style="margin: 5px 0 0 0; color: #fff;">Checking...</h3>
                </div>
                <button class="btn-cc btn-small btn-dark" onclick="checkVrcStatus()">🔄 Refresh</button>
            </div>

            <div id="vrc-verify-box" class="hidden" style="margin-top: 20px; padding: 20px; background: rgba(255, 152, 0, 0.1); border: 1px solid rgba(255, 152, 0, 0.3); border-radius: 10px;">
                <h3 style="margin: 0 0 10px 0; color: #FF9800; font-size: 1rem;">🔐 Email Verification Required</h3>
                <p style="margin: 0 0 15px 0; font-size: 0.85rem; color: #ccc;">VRChat has sent a 6-digit code to your email. Enter it below to authorize this server.</p>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="vrc-otp-code" placeholder="123456" style="flex: 1; text-align: center; letter-spacing: 5px; font-weight: bold;">
                    <button class="btn-cc btn-primary" style="margin: 0;" onclick="submitVrcCode()">Verify Code</button>
                </div>
            </div>

            <div id="vrc-connected-msg" class="hidden" style="margin-top: 15px; font-size: 0.8rem; color: #00e676; opacity: 0.8;">
                ✅ API is fully authorized and tracking group activity.
            </div>
        </div>

        <!-- DISCORD BOT STATUS -->
        <div class="staff-section" style="border-left: 4px solid #5865F2; margin: 0;">
            <h2>Discord Bot Status</h2>
            <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 10px;">
                <div>
                    <p style="margin: 0; font-size: 0.8rem; color: #888; text-transform: uppercase; letter-spacing: 1px;">Bot Connectivity</p>
                    <h3 id="discord-status-text" style="margin: 5px 0 0 0; color: #fff;">Checking...</h3>
                </div>
                <button class="btn-cc btn-small btn-dark" onclick="checkDiscordStatus()">🔄 Refresh</button>
            </div>
            <div id="discord-connected-msg" class="hidden" style="margin-top: 15px; font-size: 0.8rem; color: #5865F2; opacity: 0.8;">
                ✅ Bot is connected and listening for slash commands.
            </div>
        </div>
    </div>

    <!-- GLOBAL SETTINGS -->
    <div class="staff-section">
        <h2>Event Settings</h2>
        
        <% const userType = user.type.toLowerCase(); %>
        <% const canManageAll = userType.includes('host') || userType.includes('owner'); %>

        <div class="form-group" style="margin-bottom: 15px;">
            <label>Event Title</label>
            <input type="text" id="event-title" placeholder="e.g. Neon Nights / Summer Splash" <%= canManageAll ? '' : 'disabled' %>>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label>Event Start (UTC)</label>
                <input type="datetime-local" id="event-start" <%= canManageAll ? '' : 'disabled' %>>
            </div>
            <div class="form-group">
                <label>Event End (UTC)</label>
                <input type="datetime-local" id="event-end" <%= canManageAll ? '' : 'disabled' %>>
            </div>
        </div>

        <div class="grid-2" style="margin-top: 15px;">
            <div class="form-group">
                <label>Event Theme (CSS Class)</label>
                <select id="event-theme-select" onchange="toggleCustomTheme()" <%= canManageAll ? '' : 'disabled' %>>
                    <option value="">Default (Club Critters)</option>
                    <option value="theme-halloween">🎃 Halloween</option>
                    <option value="theme-christmas">🎄 Christmas</option>
                    <option value="theme-pride">🌈 Pride</option>
                    <option value="theme-valentines">💖 Valentine's</option>
                    <option value="theme-summer">☀️ Summer/Beach</option>
                    <option value="theme-rain">🌧️ Tropical Rain</option>
                    <option value="custom">Custom Class...</option>
                </select>
                <input type="text" id="event-theme-custom" placeholder="e.g. theme-anniversary" class="hidden" style="margin-top: 5px;">
            </div>
            <div class="form-group">
                <label>Custom Event Logo URL</label>
                <input type="text" id="event-logo" placeholder="/cdn/logos/club/SpecialLogo.png" <%= canManageAll ? '' : 'disabled' %>>
            </div>
        </div>

        <div class="form-group" style="margin-top: 15px;">
            <label>VRChat Instance URL / Override</label>
            <input type="text" id="instance-url" placeholder="https://vrchat.com/home/launch?worldId=...">
            <p style="font-size: 0.7rem; color: #666; margin-top: 5px;">Tip: Leave empty to auto-track the group's active instance (set in .env).</p>
        </div>
        <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
            <input type="checkbox" id="force-offline" style="width: auto;" <%= canManageAll ? '' : 'disabled' %>>
            <label style="margin: 0;">Force Site Offline</label>
        </div>
        <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-top: 10px;">
            <input type="checkbox" id="maintenance-mode" style="width: auto;" <%= canManageAll ? '' : 'disabled' %>>
            <label style="margin: 0; color: #ff9800;">🛠️ Maintenance Mode</label>
            <p style="font-size: 0.7rem; color: #666; margin: 0; margin-left: auto;">Shuts down public hub but allows panel access.</p>
        </div>
        <button class="btn-cc btn-primary" style="width: 100%;" onclick="saveSettings()">Update Global Settings</button>
        
        <% if (!canManageAll) { %>
            <p style="font-size: 0.75rem; color: #666; margin-top: 15px;">Note: You can only update the VRChat Instance URL. Only Hosts and Owners can change event times and themes.</p>
        <% } %>
    </div>
    <!-- MULTI-INSTANCE TRACKING -->
    <div class="staff-section" style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 30px; margin-top: 30px;">
        <h2 style="color: var(--primary-purple);">Manage Active Instances</h2>
        <p style="font-size: 0.8rem; color: #888; margin-bottom: 20px;">Track multiple instances simultaneously (e.g., Overflow instances). These contribute to the total player count shown on the hub.</p>
        
        <% if (canManageAll) { %>
        <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 10px; margin-bottom: 20px;">
            <div style="display: flex; gap: 10px; align-items: flex-end;">
                <div class="form-group" style="flex: 1; margin: 0;">
                    <label>Add Instance URL</label>
                    <input type="text" id="new-instance-url" placeholder="https://vrchat.com/home/launch?worldId=...">
                </div>
                <div class="form-group" style="margin: 0; display: flex; align-items: center; gap: 5px; padding-bottom: 12px;">
                    <input type="checkbox" id="new-instance-event" style="width: auto;">
                    <label style="margin: 0; font-size: 0.7rem;">Event Session</label>
                </div>
                <button class="btn-cc btn-primary" style="margin: 0;" onclick="startInstanceTracking()">Track Instance</button>
            </div>
        </div>
        <% } %>

        <div id="active-instances-list" class="schedule-list">
            <!-- Active instances will appear here -->
            <p style="text-align: center; color: #555; font-size: 0.8rem; padding: 20px;">No additional instances currently being tracked.</p>
        </div>
    </div>

</div>

<script>
    const eventStartInput = document.getElementById('event-start');
    const eventEndInput = document.getElementById('event-end');
    const eventTitleInput = document.getElementById('event-title');
    const instanceUrlInput = document.getElementById('instance-url');
    const forceOfflineInput = document.getElementById('force-offline');
    const maintenanceModeInput = document.getElementById('maintenance-mode');
    const eventThemeSelect = document.getElementById('event-theme-select');
    const eventThemeCustom = document.getElementById('event-theme-custom');
    const eventLogoInput = document.getElementById('event-logo');
    const instancesList = document.getElementById('active-instances-list');

    function toggleCustomTheme() {
        if (eventThemeSelect.value === 'custom') {
            eventThemeCustom.classList.remove('hidden');
        } else {
            eventThemeCustom.classList.add('hidden');
        }
    }

    async function loadSettings() {
        try {
            const setRes = await fetch('/api/settings');
            const settings = await setRes.json();
            
            if (settings) {
                if (settings.eventStartTime) eventStartInput.value = settings.eventStartTime.slice(0, 16);
                if (settings.eventEndTime) eventEndInput.value = settings.eventEndTime.slice(0, 16);
                if (eventTitleInput) eventTitleInput.value = settings.eventTitle || '';
                instanceUrlInput.value = settings.instanceUrl || '';
                if (forceOfflineInput) forceOfflineInput.checked = settings.forceOffline;
                if (maintenanceModeInput) maintenanceModeInput.checked = settings.maintenanceMode || false;

                // Handle Theme selection
                const predefinedThemes = ['theme-halloween', 'theme-christmas', 'theme-pride', 'theme-valentines', 'theme-summer', 'theme-rain'];
                if (!settings.eventTheme) {
                    eventThemeSelect.value = "";
                } else if (predefinedThemes.includes(settings.eventTheme)) {
                    eventThemeSelect.value = settings.eventTheme;
                } else {
                    eventThemeSelect.value = "custom";
                    eventThemeCustom.value = settings.eventTheme;
                    eventThemeCustom.classList.remove('hidden');
                }
                
                eventLogoInput.value = settings.eventLogo || '';
            }
        } catch (e) { console.error("Error loading settings:", e); }
        
        // Ensure status checks run even if settings fail
        checkVrcStatus();
        checkDiscordStatus();
        loadActiveInstances();
    }

    async function loadActiveInstances() {
        try {
            const res = await fetch('/api/vrchat/instances');
            const instances = await res.json();
            
            if (!instances || instances.length === 0) {
                instancesList.innerHTML = '<p style="text-align: center; color: #555; font-size: 0.8rem; padding: 20px;">No additional instances currently being tracked.</p>';
                return;
            }

            instancesList.innerHTML = instances.map(inst => `
                <li class="schedule-item" style="border-left: 4px solid ${inst.isEventSession ? 'var(--primary-blue)' : '#888'};">
                    <div style="flex:1;">
                        <strong>${inst.worldName}</strong> 
                        <span style="font-size: 0.7rem; color: #888; display: block;">ID: ${inst.instanceId}</span>
                        <div style="margin-top: 5px;">
                            <span class="btn-cc btn-small" style="font-size: 0.6rem; background: ${inst.isEventSession ? 'rgba(41, 197, 246, 0.1)' : 'rgba(255,255,255,0.05)'}; color: ${inst.isEventSession ? 'var(--primary-blue)' : '#888'};">
                                ${inst.isEventSession ? 'EVENT SESSION' : 'CASUAL SESSION'}
                            </span>
                        </div>
                    </div>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <button onclick="stopInstanceTracking(${inst.id})" class="btn-cc btn-small btn-danger">Stop Tracking</button>
                    </div>
                </li>
            `).join('');
        } catch (e) { console.error("Error loading instances:", e); }
    }

    async function startInstanceTracking() {
        const url = document.getElementById('new-instance-url').value;
        const isEvent = document.getElementById('new-instance-event').checked;
        if (!url) return showNotify('URL is required', 'error');

        try {
            const res = await fetch('/api/vrchat/instances/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ instanceUrl: url, isEventSession: isEvent })
            });
            if (res.ok) {
                showNotify('Instance tracking started!');
                document.getElementById('new-instance-url').value = '';
                loadActiveInstances();
            } else {
                showNotify('Failed to start tracking.', 'error');
            }
        } catch (e) { showNotify('Network error', 'error'); }
    }

    async function stopInstanceTracking(id) {
        if (!confirm('Stop tracking this instance? This will finalize the log.')) return;
        try {
            const res = await fetch(`/api/vrchat/instances/${id}/stop`, { method: 'DELETE' });
            if (res.ok) {
                showNotify('Tracking stopped.');
                loadActiveInstances();
            }
        } catch (e) { showNotify('Network error', 'error'); }
    }

    async function checkDiscordStatus() {
        try {
            const res = await fetch('/api/discord/status');
            const data = await res.json();
            const text = document.getElementById('discord-status-text');
            const connectedMsg = document.getElementById('discord-connected-msg');
            
            const status = data.status || 'Offline';
            text.innerText = status;
            
            if (status.includes('Connected')) {
                text.style.color = '#5865F2';
                connectedMsg.classList.remove('hidden');
            } else {
                text.style.color = '#ff5252';
                connectedMsg.classList.add('hidden');
            }
        } catch (e) { console.error("Error checking Discord status:", e); }
    }

    async function checkVrcStatus() {
        try {
            const res = await fetch('/api/vrchat/status');
            const data = await res.json();
            const text = document.getElementById('vrc-status-text');
            const verifyBox = document.getElementById('vrc-verify-box');
            const connectedMsg = document.getElementById('vrc-connected-msg');
            
            const status = data.status || 'Disconnected';
            text.innerText = status;
            
            if (status === 'Connected') {
                text.style.color = '#00e676';
                verifyBox.classList.add('hidden');
                connectedMsg.classList.remove('hidden');
            } else if (status === '2FA Required') {
                text.style.color = '#FF9800';
                verifyBox.classList.remove('hidden');
                connectedMsg.classList.add('hidden');
            } else {
                text.style.color = '#ff5252';
                verifyBox.classList.add('hidden');
                connectedMsg.classList.add('hidden');
            }
        } catch (e) { console.error("Error checking VRC status:", e); }
    }

    async function submitVrcCode() {
        const code = document.getElementById('vrc-otp-code').value.trim();
        if (!code) return showNotify('Enter code first', 'error');

        try {
            const res = await fetch('/api/vrchat/verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code })
            });
            const data = await res.json();
            if (data.success) {
                showNotify('VRChat Verified!');
                checkVrcStatus();
            } else {
                showNotify(data.message || 'Verification failed', 'error');
            }
        } catch (e) { showNotify('Error connecting to server', 'error'); }
    }

    async function saveSettings() {
        try {
            let theme = eventThemeSelect.value;
            if (theme === 'custom') theme = eventThemeCustom.value.trim();

            const response = await fetch('/api/settings/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    eventStartTime: eventStartInput.value,
                    eventEndTime: eventEndInput.value,
                    eventTitle: eventTitleInput ? eventTitleInput.value.trim() : '',
                    instanceUrl: instanceUrlInput.value,
                    forceOffline: forceOfflineInput ? forceOfflineInput.checked : false,
                    maintenanceMode: maintenanceModeInput ? maintenanceModeInput.checked : false,
                    eventTheme: theme,
                    eventLogo: eventLogoInput.value.trim()
                })
            });
            if (response.ok) {
                showNotify('Settings updated successfully!');
                // Re-check status if URL changed
                setTimeout(checkVrcStatus, 1000);
            } else {
                showNotify('Failed to update settings.', 'error');
            }
        } catch (e) {
            showNotify('Network error occurred.', 'error');
        }
    }

    loadSettings();
    // Auto-refresh status while on this page
    setInterval(() => {
        checkVrcStatus();
        checkDiscordStatus();
    }, 10000);
</script>

<%- include('footer') %>
