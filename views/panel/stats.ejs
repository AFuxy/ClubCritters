<%- include('header') %>

<style>
    /* CUSTOM SCROLLBAR FOR STATS */
    .scrollable-stats {
        max-height: 300px;
        overflow-y: auto;
        padding-right: 10px;
        margin-top: 15px;
    }
    .scrollable-stats::-webkit-scrollbar { width: 6px; }
    .scrollable-stats::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); border-radius: 10px; }
    .scrollable-stats::-webkit-scrollbar-thumb { background: currentColor; border-radius: 10px; }

    /* VIBRANT STAT BLOCK STYLES */
    .stat-block { 
        position: relative; 
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(255,255,255,0.05);
        background: linear-gradient(145deg, rgba(21, 30, 41, 0.9), rgba(11, 16, 22, 0.9)) !important;
        overflow: hidden;
    }
    
    .stat-block:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    }

    .stat-block::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: currentColor;
        box-shadow: 0 0 15px currentColor;
    }

    .stat-block h2 {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #fff !important;
        border-bottom: 1px solid rgba(255,255,255,0.1) !important;
    }

    .stat-block h2::before {
        content: '';
        width: 8px; height: 8px;
        border-radius: 50%;
        background: currentColor;
        box-shadow: 0 0 10px currentColor;
    }

    /* UNIQUE ACCENT COLORS */
    .accent-blue   { color: #29C5F6 !important; }
    .accent-green  { color: #00e676 !important; }
    .accent-purple { color: #B36AF4 !important; }
    .accent-orange { color: #FF9800 !important; }
    .accent-pink   { color: #E91E63 !important; }

    .stat-value-highlight {
        font-weight: 900;
        font-size: 1.1rem;
        text-shadow: 0 0 10px rgba(0,0,0,0.5);
    }

    .schedule-item {
        background: rgba(255,255,255,0.03) !important;
        border: 1px solid rgba(255,255,255,0.05);
        margin-bottom: 8px;
        border-left: 4px solid currentColor !important; /* Single thick accent border */
        padding-left: 15px !important;
    }
    .schedule-item::before { display: none !important; } /* Remove the bar from admin.css to prevent double borders */
</style>

<div class="staff-hub">
    <h1 style="text-align: center; margin-bottom: 40px; color: #fff; font-weight: 900; letter-spacing: 2px;">GLOBAL SITE ANALYTICS</h1>

    <div class="grid-2">
        <!-- 1. PAGE VIEW BREAKDOWN (BLUE) -->
        <div class="staff-section stat-block accent-blue">
            <h2>Page View Breakdown</h2>
            <div class="scrollable-stats">
                <ul id="page-views-list" class="schedule-list" style="margin-top: 0;"></ul>
            </div>
        </div>

        <!-- 2. APPLICATION INTEREST (GREEN) -->
        <div class="staff-section stat-block accent-green">
            <h2>Application Interest</h2>
            <div class="scrollable-stats">
                <ul id="app-interest-list" class="schedule-list" style="margin-top: 0;"></ul>
            </div>
        </div>
    </div>

    <div class="grid-2" style="margin-top: 30px;">
        <!-- 3. TOP SOCIAL PLATFORMS (PURPLE) -->
        <div class="staff-section stat-block accent-purple">
            <h2>Most Popular Platforms</h2>
            <div class="scrollable-stats">
                <ul id="top-platforms-list" class="schedule-list" style="margin-top: 0;"></ul>
            </div>
        </div>

        <!-- 4. TOP DJ IMPACT (ORANGE) -->
        <div class="staff-section stat-block accent-orange">
            <h2>Top DJ Impact</h2>
            <div class="scrollable-stats">
                <ul id="top-djs" class="schedule-list" style="margin-top: 0;"></ul>
            </div>
        </div>
    </div>

    <!-- 5. TOP ARCHIVE SETS (PINK) -->
    <div class="staff-section stat-block accent-pink" style="margin-top: 30px;">
        <h2>Top Archive Sets</h2>
        <div class="scrollable-stats" style="max-height: 400px;">
            <ul id="top-archives" class="schedule-list" style="margin-top: 0;"></ul>
        </div>
    </div>

    <!-- 6. HISTORICAL INSTANCE SESSIONS (CYAN) -->
    <div class="staff-section stat-block accent-blue" style="margin-top: 30px; color: #00bcd4 !important;">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; margin-bottom: 15px;">
            <h2 style="border:none !important; margin:0 !important;">Historical Instance Sessions</h2>
            <button onclick="openLogModal()" class="btn-cc btn-small btn-primary">+ Add Past Event</button>
        </div>
        <div class="scrollable-stats" style="max-height: 500px;">
            <table style="width: 100%; border-collapse: collapse; color: #eee; font-size: 0.9rem;">
                <thead>
                    <tr style="text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1); color: #888;">
                        <th style="padding: 10px;">World / ID</th>
                        <th style="padding: 10px;">Type</th>
                        <th style="padding: 10px;">Date</th>
                        <th style="padding: 10px;">Peak/Unique</th>
                        <th style="padding: 10px;">Duration</th>
                        <th style="padding: 10px;">Actions</th>
                    </tr>
                </thead>
                <tbody id="instance-logs-body">
                    <!-- Logs will be injected here -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Log Modal -->
<div id="log-modal" class="modal-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:1000; justify-content:center; align-items:center;">
    <div class="staff-section stat-block accent-blue" style="width: 500px; max-width: 90%; background:#151e29 !important;">
        <h2 id="modal-title">Add Manual Event Log</h2>
        <form id="log-form" style="margin-top:20px;">
            <input type="hidden" name="id" id="log-id">
            <div class="form-group" style="margin-bottom:15px;">
                <label style="display:block; color:#888; margin-bottom:5px;">World Name</label>
                <input type="text" name="worldName" id="log-worldName" value="Club Critters Hub" class="search-bar" style="width:100%;" required>
            </div>
            <div class="grid-2" style="gap:15px; margin-bottom:15px;">
                <div>
                    <label style="display:block; color:#888; margin-bottom:5px;">Start Time</label>
                    <input type="datetime-local" name="startTime" id="log-startTime" class="search-bar" style="width:100%;" required>
                </div>
                <div>
                    <label style="display:block; color:#888; margin-bottom:5px;">End Time</label>
                    <input type="datetime-local" name="endTime" id="log-endTime" class="search-bar" style="width:100%;" required>
                </div>
            </div>
            <div class="grid-2" style="gap:15px; margin-bottom:15px;">
                <div>
                    <label style="display:block; color:#888; margin-bottom:5px;">Peak Capacity</label>
                    <input type="number" name="peakCapacity" id="log-peakCapacity" value="0" class="search-bar" style="width:100%;" required>
                </div>
                <div>
                    <label style="display:block; color:#888; margin-bottom:5px;">Unique Users</label>
                    <input type="number" name="uniqueUsers" id="log-uniqueUsers" value="0" class="search-bar" style="width:100%;" required>
                </div>
            </div>
            <div style="margin-bottom:20px;">
                <label style="display:flex; align-items:center; gap:10px; color:#eee; cursor:pointer;">
                    <input type="checkbox" name="isEventSession" id="log-isEventSession" checked> Mark as Public Event?
                </label>
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px;">
                <button type="button" onclick="closeLogModal()" class="btn-cc btn-small btn-secondary">Cancel</button>
                <button type="submit" class="btn-cc btn-small btn-primary">Save Entry</button>
            </div>
        </form>
    </div>
</div>

<script>
    let allLogs = [];

    async function loadGlobalStats() {
        try {
            const res = await fetch('/api/stats/global');
            const data = await res.json();

            // Render Page Views
            document.getElementById('page-views-list').innerHTML = data.pageViews.map(p => `
                <li class="schedule-item">
                    <span style="text-transform: capitalize;">${p.page} Page</span>
                    <span class="stat-value-highlight" style="color: #29C5F6;">${p.count.toLocaleString()} views</span>
                </li>
            `).join('');

            // Render App Interest
            const appList = document.getElementById('app-interest-list');
            if (data.appInterest && data.appInterest.length > 0) {
                appList.innerHTML = data.appInterest.map(a => `
                    <li class="schedule-item">
                        <span>${a.label}</span>
                        <span class="stat-value-highlight" style="color: #00e676;">${a.count.toLocaleString()} clicks</span>
                    </li>
                `).join('');
            } else { appList.innerHTML = '<p style="text-align:center; padding:20px; color:#666;">No data yet.</p>'; }

            // Render Top Platforms
            const topPlatformsList = document.getElementById('top-platforms-list');
            if (data.topPlatforms.length > 0) {
                topPlatformsList.innerHTML = data.topPlatforms.map(p => `
                    <li class="schedule-item">
                        <span>${p.label}</span>
                        <span class="stat-value-highlight" style="color: #B36AF4;">${p.count.toLocaleString()} clicks</span>
                    </li>
                `).join('');
            } else { topPlatformsList.innerHTML = '<p style="text-align:center; padding:20px; color:#666;">No data yet.</p>'; }

            // Render Top DJs
            const topDJsList = document.getElementById('top-djs');
            if (data.topDJs.length > 0) {
                topDJsList.innerHTML = data.topDJs.map(dj => `
                    <li class="schedule-item">
                        <span>${dj.name}</span>
                        <span class="stat-value-highlight" style="color: #FF9800;">${dj.count.toLocaleString()} clicks</span>
                    </li>
                `).join('');
            } else { topDJsList.innerHTML = '<p style="text-align:center; padding:20px; color:#666;">No data yet.</p>'; }

            // Render Top Archives
            const topArchivesList = document.getElementById('top-archives');
            if (data.topArchives.length > 0) {
                topArchivesList.innerHTML = data.topArchives.map(arc => `
                    <li class="schedule-item">
                        <div>
                            <span style="display: block;">${arc.title}</span>
                            <span style="font-size: 0.75rem; color: #888;">by ${arc.djName}</span>
                        </div>
                        <span class="stat-value-highlight" style="color: #E91E63;">${arc.count.toLocaleString()} listens</span>
                    </li>
                `).join('');
            } else { topArchivesList.innerHTML = '<p style="text-align:center; padding:20px; color:#666;">No data yet.</p>'; }

            // 6. Render Historical Instance Logs
            const logRes = await fetch('/api/stats/instances');
            allLogs = await logRes.json();
            const logBody = document.getElementById('instance-logs-body');
            
            if (allLogs.length > 0) {
                logBody.innerHTML = allLogs.map(log => {
                    const date = new Date(log.startTime).toLocaleDateString();
                    const duration = log.totalDuration ? `${Math.floor(log.totalDuration / 60)}h ${log.totalDuration % 60}m` : 'Active...';
                    const typeBadge = log.isEventSession 
                        ? '<span style="color:#ff4444; font-weight:bold;">LIVE</span>' 
                        : '<span style="color:#00bcd4;">Social</span>';
                    
                    const uniqueStr = log.uniqueUsers > 0 ? `<br><span style="font-size:0.75rem; color:#888;">Uniq: ${log.uniqueUsers}</span>` : "";

                    return `
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td style="padding: 10px;">
                                <div style="font-weight:bold;">${log.worldName}</div>
                                <div style="font-size:0.7rem; opacity:0.5; font-family:monospace;">${log.instanceId}</div>
                            </td>
                            <td style="padding: 10px;">${typeBadge}</td>
                            <td style="padding: 10px;">${date}</td>
                            <td style="padding: 10px; color: #00e676; font-weight:bold;">
                                ${log.peakCapacity} ${uniqueStr}
                            </td>
                            <td style="padding: 10px; opacity:0.8;">${duration}</td>
                            <td style="padding: 10px; display:flex; gap:10px;">
                                <button onclick="editLog(${log.id})" style="background:none; border:none; color:#29C5F6; cursor:pointer; font-size:1.2rem;" title="Edit">✏️</button>
                                <button onclick="deleteLog(${log.id})" style="background:none; border:none; color:#ff5252; cursor:pointer; font-size:1.2rem;" title="Delete">🗑️</button>
                            </td>
                        </tr>
                    `;
                }).join('');
            } else {
                logBody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px; color:#666;">No session data recorded yet.</td></tr>';
            }

        } catch (err) { console.error("Failed to load stats:", err); }
    }
    loadGlobalStats();

    function openLogModal(log = null) {
        const modal = document.getElementById('log-modal');
        const form = document.getElementById('log-form');
        const title = document.getElementById('modal-title');
        
        form.reset();
        document.getElementById('log-id').value = "";
        
        if (log) {
            title.innerText = "Edit Event Log";
            document.getElementById('log-id').value = log.id;
            document.getElementById('log-worldName').value = log.worldName;
            document.getElementById('log-startTime').value = new Date(log.startTime).toISOString().slice(0, 16);
            if (log.endTime) document.getElementById('log-endTime').value = new Date(log.endTime).toISOString().slice(0, 16);
            document.getElementById('log-peakCapacity').value = log.peakCapacity;
            document.getElementById('log-uniqueUsers').value = log.uniqueUsers;
            document.getElementById('log-isEventSession').checked = log.isEventSession;
        } else {
            title.innerText = "Add Manual Event Log";
        }
        
        modal.style.display = 'flex';
    }

    function closeLogModal() {
        document.getElementById('log-modal').style.display = 'none';
    }

    function editLog(id) {
        const log = allLogs.find(l => l.id === id);
        if (log) openLogModal(log);
    }

    // Handle Form Submission
    document.getElementById('log-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        data.isEventSession = formData.get('isEventSession') === 'on';
        
        const id = document.getElementById('log-id').value;
        const method = id ? 'PATCH' : 'POST';
        const url = id ? `/api/stats/instances/${id}` : '/api/stats/instances/add';

        try {
            const res = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            if (res.ok) {
                closeLogModal();
                loadGlobalStats();
            }
        } catch (err) { alert("Failed to save entry."); }
    });

    async function deleteLog(id) {
        if (!confirm("Are you sure you want to delete this log entry?")) return;
        try {
            const res = await fetch(`/api/stats/instances/${id}`, { method: 'DELETE' });
            if (res.ok) loadGlobalStats();
        } catch (err) { alert("Failed to delete."); }
    }
</script>

<%- include('footer') %>