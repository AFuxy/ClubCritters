<div style="display:flex; justify-content:center; gap:10px; margin-bottom: 20px;">
    <% if (page === 'index') { %>
        <a href="/archive" id="archive-link" class="btn-cc nav-pill-cc">📂 Archive</a>
        <a href="/events" id="events-link" class="btn-cc nav-pill-cc">📊 Events</a>
        <a href="/gallery" id="gallery-link" class="btn-cc nav-pill-cc">📸 Gallery</a>
        <a href="/team" class="btn-cc nav-pill-cc">👥 Team</a>
    <% } else { %>
        <a href="/" class="btn-cc nav-pill-cc">← Back to Hub</a>
        <% if (page !== 'archive') { %><a href="/archive" class="btn-cc nav-pill-cc">📂 Archive</a><% } %>
        <% if (page !== 'events') { %><a href="/events" class="btn-cc nav-pill-cc">📊 Events</a><% } %>
        <% if (page !== 'gallery') { %><a href="/gallery" class="btn-cc nav-pill-cc">📸 Gallery</a><% } %>
        <% if (page !== 'team') { %><a href="/team" class="btn-cc nav-pill-cc">👥 Team</a><% } %>
    <% } %>
</div>
