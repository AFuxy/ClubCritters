<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { 
    title: displayName, 
    page: 'performer',
    description: performer.bio ? performer.bio.substring(0, 160) : 'Musical sets and profile info for ' + displayName,
    themeColor: '#29C5F6'
}) %>
<% 
    function parseColor(val) {
        if (!val) return '#29C5F6';
        if (val.startsWith('[') && val.endsWith(']')) {
            const colors = val.slice(1, -1).split(',').map(c => c.trim());
            return `linear-gradient(135deg, ${colors.join(', ')})`;
        }
        return val;
    }
    const accent = parseColor(performer.colorStyle);

    const platformColors = {
        'youtube': '#FF0000',
        'yt': '#FF0000',
        'twitch': '#9146FF',
        'twitter': '#1DA1F2',
        'x': '#1DA1F2',
        'soundcloud': '#FF5500',
        'mixcloud': '#52AAD8',
        'bluesky': '#0085FF',
        'tiktok': '#00f2ea',
        'discord': '#5865F2',
        'linktree': '#43e55e',
        'allmylinks': '#007bff'
    };
%>

<style>
    body { 
        background: var(--dark-bg); 
        color: white; 
        font-family: 'Segoe UI', Roboto, sans-serif; 
        margin: 0; padding: 0; 
        overflow-x: hidden;
    }

    /* FIXED HEIGHT HERO - NO JITTER */
    .hero {
        height: 400px;
        width: 100%;
        background: linear-gradient(to bottom, rgba(0,0,0,0.2), var(--dark-bg)), var(--accent-gradient);
        position: relative;
        box-sizing: border-box;
        display: flex;
        justify-content: center;
    }
    
    .profile-header { 
        display: flex; 
        align-items: center; 
        gap: 40px; 
        max-width: 1200px; 
        width: 90%; 
        height: 100%;
        padding: 0;
        box-sizing: border-box;
        z-index: 2; 
    }

    /* GRADIENT BORDER LOGIC FOR CIRCLE */
    .profile-img-wrap {
        width: 180px; height: 180px;
        border-radius: 50%;
        padding: 6px;
        background: var(--accent-gradient);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .profile-img { 
        width: 100%; height: 100%;
        border-radius: 50%; 
        border: 6px solid var(--dark-bg); 
        object-fit: cover; 
        box-sizing: border-box;
    }

    .profile-info {
        flex: 1;
        min-width: 0; 
    }

    .profile-info h1 { 
        font-size: 3.5rem; 
        margin: 0; 
        line-height: 1.1;
        text-shadow: 0 5px 15px rgba(0,0,0,0.5); 
        font-weight: 900;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .profile-info .title { 
        font-size: 1.2rem; 
        color: var(--primary-blue); 
        font-weight: bold; 
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-top: 5px;
        display: block;
        opacity: 0.8;
    }

    /* STANDARDIZED PAGE WIDTH */
    .performer-container { 
        max-width: 1200px; 
        width: 90%;
        margin: -40px auto 60px auto; 
        display: grid; 
        grid-template-columns: 350px 1fr; 
        gap: 30px; 
        box-sizing: border-box;
        position: relative;
        z-index: 5;
    }
    
    /* STANDARDIZED SECTION BOXES */
    .section-box { 
        background: var(--card-bg); 
        padding: 25px; 
        border-radius: 20px; 
        border: 1px solid rgba(255,255,255,0.05); 
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        min-height: 180px; 
        display: flex;
        flex-direction: column;
    }

    .section-box h2 { 
        margin-top: 0; 
        font-size: 0.8rem; 
        text-transform: uppercase; 
        letter-spacing: 2px; 
        color: var(--primary-blue); 
        border-bottom: 1px solid rgba(255,255,255,0.1); 
        padding-bottom: 15px; 
        margin-bottom: 20px; 
        flex-shrink: 0;
    }
    
    .bio-text { 
        color: #ccc; 
        line-height: 1.7; 
        white-space: pre-wrap; 
        font-size: 1rem;
        flex-grow: 1;
    }
    
    .social-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex-grow: 1;
    }

    .social-link-btn {
        display: flex; align-items: center; justify-content: space-between;
        background: rgba(255,255,255,0.03); 
        color: #bbb !important; 
        text-decoration: none;
        padding: 0 25px; 
        border-radius: 30px; 
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255,255,255,0.08);
        font-weight: 600;
        font-size: 0.95rem;
        height: 54px; 
        box-sizing: border-box;
        text-transform: none;
        letter-spacing: 0.5px;
    }
    
    .social-link-btn:hover { 
        background: var(--hover-color, var(--accent-gradient)); 
        color: white !important;
        border-color: transparent; 
        transform: translateX(10px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.4), 0 0 15px var(--hover-color, var(--primary-blue));
    }

    .social-link-btn span:last-child {
        font-size: 1.2rem;
        opacity: 0.5;
        transition: transform 0.3s;
    }
    .social-link-btn:hover span:last-child {
        transform: translateX(5px);
        opacity: 1;
    }

    /* UPDATED ARCHIVE DESIGN TO MATCH MAIN ARCHIVE PAGE */
    .archive-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        position: relative;
    }
    .archive-row:last-child { border-bottom: none; }
    
    .row-info { display: flex; flex-direction: column; gap: 4px; }
    
    .row-title { 
        font-size: 1.05rem; 
        font-weight: 600; 
        color: #eee;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
    }
    
    .genre-tag {
        font-size: 0.7rem;
        background: rgba(255,255,255,0.1);
        padding: 2px 8px;
        border-radius: 4px;
        color: #aaa;
        text-transform: uppercase;
        font-weight: bold;
    }
    
    .row-date { 
        font-size: 0.85rem; 
        color: var(--primary-blue);
        opacity: 0.8;
    }

    @media (max-width: 1000px) {
        .performer-container { grid-template-columns: 1fr; margin-top: 20px; width: 95%; }
        .hero { height: auto; padding: 80px 20px 60px 20px; }
        .profile-header { flex-direction: column; text-align: center; gap: 20px; width: 100%; }
        .profile-info h1 { font-size: 2.5rem; white-space: normal; }
        .archive-row { flex-direction: column; align-items: flex-start; gap: 15px; }
    }
</style>
<body style="--accent-gradient: <%= accent %>;">

    <div class="hero">
        <a href="/team" class="btn-cc nav-pill-cc" style="position: absolute; top: 30px; left: 30px; z-index: 10;">&larr; BACK TO TEAM</a>
        
        <div class="profile-header">
            <div class="profile-img-wrap">
                <img src="<%= performer.imageUrl || '/cdn/logos/club/HeadOnly.png' %>" class="profile-img" onerror="this.src='/cdn/logos/club/HeadOnly.png'">
            </div>
            <div class="profile-info">
                <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                    <h1 style="color: <%= accent.includes('gradient') ? 'white' : accent %>;"><%= displayName %></h1>
                    
                    <% if (liveStatus === 'live') { %>
                        <span class="live-tag">
                            ON AIR 
                            <div class="visualizer"><div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div></div>
                        </span>
                    <% } else if (liveStatus === 'scheduled') { %>
                        <span style="background: var(--primary-blue); color: black; font-size: 0.75rem; font-weight: 900; padding: 4px 12px; border-radius: 5px; text-transform: uppercase; letter-spacing: 1px;">
                            Scheduled
                        </span>
                    <% } %>
                </div>

                <span class="title">
                    <%= performer.title || performer.type %>
                    <% if (activeSlot) { %>
                        <span id="local-time-slot" style="color: white; opacity: 0.5; margin-left: 10px; font-size: 0.9rem; text-transform: none; letter-spacing: 0;">
                            • Playing at <%= activeSlot.timeSlot %>
                        </span>
                    <% } %>
                </span>
            </div>
        </div>
    </div>

    <div class="performer-container">
        
        <div class="sidebar">
            <div class="section-box" style="margin-bottom: 25px;">
                <h2>About</h2>
                <div class="bio-text"><%= performer.bio || 'No bio available yet.' %></div>
            </div>

            <div class="section-box">
                <h2>Connect</h2>
                <div class="social-list">
                    <% const links = performer.links || {}; %>
                    <% if (Object.keys(links).length > 0) { %>
                        <% Object.keys(links).forEach(label => { 
                            const lowerLabel = label.toLowerCase();
                            const hoverColor = platformColors[lowerLabel] || null;
                        %>
                            <a href="<%= links[label] %>" 
                               target="_blank" 
                               class="btn-cc social-link-btn" 
                               style="<%= hoverColor ? '--hover-color: ' + hoverColor : '' %>"
                               onclick="trackClick('link_click', '<%= performer.discordId %>', '<%= label %>')">
                                <span><%= label %></span>
                                <span>&rarr;</span>
                            </a>
                        <% }); %>
                    <% } else { %>
                        <p style="color:#666; font-size:0.8rem;">No links found.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="main-content">
            <div class="section-box">
                <h2>Archives</h2>
                <div class="archive-list">
                    <% if (archives.length > 0) { %>
                        <% archives.forEach(arc => { %>
                            <div class="archive-row">
                                <div class="row-info">
                                    <div class="row-title">
                                        <%= arc.title %> 
                                        <span class="genre-tag"><%= arc.genre %></span>
                                    </div>
                                    <div class="row-date"><%= new Date(arc.date).toLocaleDateString(undefined, { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                                </div>
                                <a href="<%= arc.linkUrl %>" target="_blank" class="btn-cc btn-small btn-secondary" 
                                   onclick="trackClick('archive_click', '<%= arc.id %>', 'performer_page')">▶ Listen</a>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color:#666; text-align:center; padding:20px;">No sets found.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script src="/cdn/js/theme-engine.js"></script>
    <script>
        // --- TIMEZONE LOGIC ---
        const eventStartTime = "<%= eventStartTime %>";
        const rawTimeSlot = "<%= activeSlot ? activeSlot.timeSlot : '' %>";

        function updateLocalTime() {
            if (!eventStartTime || !rawTimeSlot) return;
            
            const timeSpan = document.getElementById('local-time-slot');
            const times = rawTimeSlot.match(/(\d{1,2}):(\d{2})/g);
            if (!times || times.length < 2) return;

            try {
                const tzCode = Intl.DateTimeFormat(undefined, { timeZoneName: 'short' })
                    .formatToParts(new Date())
                    .find(part => part.type == 'timeZoneName').value;

                const eventDate = new Date(eventStartTime);
                const [startH, startM] = times[0].split(':').map(Number);
                const [endH, endM] = times[1].split(':').map(Number);

                const start = new Date(eventDate);
                start.setUTCHours(startH, startM, 0, 0);
                const end = new Date(eventDate);
                end.setUTCHours(endH, endM, 0, 0);

                // Roll-over logic
                if (startH < eventDate.getUTCHours() - 6) { 
                    start.setDate(start.getDate() + 1);
                    end.setDate(end.getDate() + 1);
                } else if (end < start) {
                    end.setDate(end.getDate() + 1);
                }

                const timeOptions = { hour: '2-digit', minute: '2-digit' };
                const localDisplay = `• Playing at ${start.toLocaleTimeString([], timeOptions)} - ${end.toLocaleTimeString([], timeOptions)} ${tzCode}`;
                timeSpan.innerText = localDisplay;
            } catch (e) { console.error("TZ Error", e); }
        }

        // Track Page View on Load
        fetch('/api/stats/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                type: 'page_view', 
                targetId: '<%= performer.discordId %>', 
                metadata: { page: 'performer_profile' } 
            })
        }).catch(() => {});

        function trackClick(type, id, label) {
            fetch('/api/stats/track', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    type: type, 
                    targetId: id, 
                    metadata: { page: 'performer_page', label: label } 
                })
            }).catch(() => {});
        }

        async function initGlobal() {
            try {
                const res = await fetch('/api/public/settings');
                const settings = await res.json();
                window.applyGlobalSettings(settings);
            } catch (e) {}
        }

        updateLocalTime();
        initGlobal();
    </script>

</body>
</html>
