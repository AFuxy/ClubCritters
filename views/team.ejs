<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Meet the Team', page: 'team', description: 'Meet the staff and resident DJs behind Club FuRN.' }) %>
<body>

    <div class="container">
        <%- include('partials/nav', { page: 'team' }) %>

        <div class="logo-container">
            <img src="/cdn/logos/club/Logo.png" class="logo" alt="Logo">
        </div>

        <h1>Meet The Team</h1>
        <p id="status-subtext">The team running the show</p>

        <div id="loading-view">
            <div class="spinner"></div>
            <p>Loading Roster...</p>
        </div>

        <div id="staff-section" class="hidden">
            <h2 style="color:var(--primary-blue); border-bottom:1px solid #333; padding-bottom:10px; margin-bottom:20px; font-size:1.2rem;">Event Staff</h2>
            <div id="staff-list" class="team-grid"></div>
        </div>

        <div id="resident-section" class="hidden" style="margin-top: 40px;">
            <h2 style="color:var(--primary-purple); border-bottom:1px solid #333; padding-bottom:10px; margin-bottom:20px; font-size:1.2rem;">Resident Performers</h2>
            <div id="resident-list" class="team-grid"></div>
        </div>
        
        <p id="empty-msg" class="hidden" style="color:#666; margin-top:20px;">Roster not found.</p>
    </div>

    <script src="/cdn/js/theme-engine.js"></script>
    <script src="/cdn/js/team.js"></script>
</body>
</html>
